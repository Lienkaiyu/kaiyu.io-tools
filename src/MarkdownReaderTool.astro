---
---

<div class="tool-container">
    <div class="tool-panel md-toolbar">
        <div class="toolbar-group">
            <button class="tool-btn toolbar-btn" data-action="bold" title="Bold">B</button>
            <button class="tool-btn toolbar-btn italic-btn" data-action="italic" title="Italic">I</button>
            <button class="tool-btn toolbar-btn" data-action="h1" title="Heading 1">H1</button>
            <button class="tool-btn toolbar-btn" data-action="h2" title="Heading 2">H2</button>
            <button class="tool-btn toolbar-btn" data-action="code" title="Inline Code">`</button>
            <button class="tool-btn toolbar-btn" data-action="codeblock" title="Code Block">{ }</button>
            <button class="tool-btn toolbar-btn" data-action="link" title="Link">🔗</button>
            <button class="tool-btn toolbar-btn" data-action="ul" title="Unordered List">• List</button>
            <button class="tool-btn toolbar-btn" data-action="ol" title="Ordered List">1. List</button>
            <button class="tool-btn toolbar-btn" data-action="quote" title="Blockquote">" "</button>
            <button class="tool-btn toolbar-btn" data-action="hr" title="Horizontal Rule">—</button>
        </div>
        <div class="toolbar-actions">
            <button id="copy-btn" class="tool-btn tool-btn-secondary">Copy MD</button>
            <button id="clear-btn" class="tool-btn tool-btn-secondary">Clear</button>
        </div>
    </div>

    <div class="md-editor-grid">
        <div class="md-pane">
            <div class="pane-header">Editor</div>
            <textarea id="md-input" class="tool-textarea md-textarea" placeholder="Start typing Markdown here..."></textarea>
        </div>
        <div class="md-divider"></div>
        <div class="md-pane">
            <div class="pane-header">Preview</div>
            <div id="md-preview" class="md-preview"></div>
        </div>
    </div>

    <div class="md-stats">
        <span id="stat-chars">0 chars</span>
        <span id="stat-words">0 words</span>
        <span id="stat-lines">0 lines</span>
    </div>
</div>

<script>
    import { marked } from 'marked';

    const input = document.getElementById('md-input') as HTMLTextAreaElement;
    const preview = document.getElementById('md-preview') as HTMLDivElement;
    const copyBtn = document.getElementById('copy-btn');
    const clearBtn = document.getElementById('clear-btn');
    const statChars = document.getElementById('stat-chars');
    const statWords = document.getElementById('stat-words');
    const statLines = document.getElementById('stat-lines');

    marked.setOptions({ breaks: true, gfm: true });

    function updatePreview() {
        const val = input.value;
        preview.innerHTML = marked.parse(val) as string;
        const chars = val.length;
        const words = val.trim() ? val.trim().split(/\s+/).length : 0;
        const lines = val ? val.split('\n').length : 0;
        statChars!.textContent = `${chars} chars`;
        statWords!.textContent = `${words} words`;
        statLines!.textContent = `${lines} lines`;
    }

    input.addEventListener('input', updatePreview);

    function insertAt(before: string, after: string = '', placeholder: string = '') {
        const start = input.selectionStart;
        const end = input.selectionEnd;
        const selected = input.value.slice(start, end) || placeholder;
        const replacement = before + selected + after;
        input.value = input.value.slice(0, start) + replacement + input.value.slice(end);
        const cursor = start + before.length + selected.length + after.length;
        input.setSelectionRange(cursor, cursor);
        input.focus();
        updatePreview();
    }

    function insertLine(prefix: string) {
        const start = input.selectionStart;
        const lineStart = input.value.lastIndexOf('\n', start - 1) + 1;
        input.value = input.value.slice(0, lineStart) + prefix + input.value.slice(lineStart);
        input.setSelectionRange(lineStart + prefix.length, lineStart + prefix.length);
        input.focus();
        updatePreview();
    }

    document.querySelectorAll('.toolbar-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const action = (btn as HTMLElement).dataset.action;
            if (action === 'bold') insertAt('**', '**', 'bold text');
            else if (action === 'italic') insertAt('_', '_', 'italic text');
            else if (action === 'h1') insertLine('# ');
            else if (action === 'h2') insertLine('## ');
            else if (action === 'code') insertAt('`', '`', 'code');
            else if (action === 'codeblock') insertAt('```\n', '\n```', 'code here');
            else if (action === 'link') insertAt('[', '](url)', 'link text');
            else if (action === 'ul') insertLine('- ');
            else if (action === 'ol') insertLine('1. ');
            else if (action === 'quote') insertLine('> ');
            else if (action === 'hr') {
                const pos = input.selectionStart;
                const nl = input.value[pos - 1] === '\n' ? '' : '\n';
                input.value = input.value.slice(0, pos) + nl + '---\n' + input.value.slice(pos);
                input.setSelectionRange(pos + nl.length + 4, pos + nl.length + 4);
                input.focus();
                updatePreview();
            }
        });
    });

    copyBtn?.addEventListener('click', () => {
        navigator.clipboard.writeText(input.value);
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy MD'; }, 1500);
    });

    clearBtn?.addEventListener('click', () => {
        input.value = '';
        updatePreview();
    });

    updatePreview();
</script>

<style>
    .md-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        padding: 10px 14px;
    }

    .toolbar-group {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .toolbar-btn {
        padding: 4px 8px;
        font-size: 12px;
        min-width: 32px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .italic-btn {
        font-style: italic;
    }

    :global(body.light-mode) .toolbar-btn {
        border-color: rgba(0,0,0,0.12);
    }

    .toolbar-actions {
        display: flex;
        gap: 8px;
    }

    .md-editor-grid {
        display: grid;
        grid-template-columns: 1fr 1px 1fr;
        gap: 0;
        height: calc(100vh - 220px);
        min-height: 400px;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 8px;
        overflow: hidden;
    }

    :global(body.light-mode) .md-editor-grid {
        border-color: rgba(0,0,0,0.1);
    }

    .md-pane {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .pane-header {
        padding: 8px 14px;
        font-size: 12px;
        color: var(--text-muted);
        background: var(--box-bg);
        border-bottom: 1px solid rgba(255,255,255,0.06);
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    :global(body.light-mode) .pane-header {
        border-bottom-color: rgba(0,0,0,0.08);
    }

    .md-textarea {
        flex: 1;
        border: none;
        border-radius: 0;
        resize: none;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 14px;
        line-height: 1.6;
        padding: 16px;
    }

    .md-divider {
        background: rgba(255,255,255,0.08);
    }

    :global(body.light-mode) .md-divider {
        background: rgba(0,0,0,0.1);
    }

    .md-preview {
        flex: 1;
        overflow-y: auto;
        padding: 16px 20px;
        font-size: 15px;
        line-height: 1.7;
        color: var(--text-color);
    }

    .md-preview :global(h1),
    .md-preview :global(h2),
    .md-preview :global(h3) {
        margin: 1em 0 0.4em;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding-bottom: 0.2em;
    }

    :global(body.light-mode) .md-preview :global(h1),
    :global(body.light-mode) .md-preview :global(h2),
    :global(body.light-mode) .md-preview :global(h3) {
        border-bottom-color: rgba(0,0,0,0.1);
    }

    .md-preview :global(code) {
        background: rgba(255,255,255,0.08);
        padding: 2px 5px;
        border-radius: 3px;
        font-family: monospace;
        font-size: 13px;
    }

    :global(body.light-mode) .md-preview :global(code) {
        background: rgba(0,0,0,0.07);
    }

    .md-preview :global(pre) {
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        padding: 12px 16px;
        overflow-x: auto;
    }

    :global(body.light-mode) .md-preview :global(pre) {
        background: rgba(0,0,0,0.05);
    }

    .md-preview :global(pre code) {
        background: none;
        padding: 0;
    }

    .md-preview :global(blockquote) {
        border-left: 3px solid var(--color);
        padding-left: 12px;
        margin-left: 0;
        color: var(--text-muted);
    }

    .md-preview :global(a) {
        color: var(--color);
    }

    .md-preview :global(table) {
        border-collapse: collapse;
        width: 100%;
    }

    .md-preview :global(th),
    .md-preview :global(td) {
        border: 1px solid rgba(255,255,255,0.12);
        padding: 6px 12px;
    }

    :global(body.light-mode) .md-preview :global(th),
    :global(body.light-mode) .md-preview :global(td) {
        border-color: rgba(0,0,0,0.12);
    }

    .md-preview :global(hr) {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.1);
        margin: 1.5em 0;
    }

    :global(body.light-mode) .md-preview :global(hr) {
        border-top-color: rgba(0,0,0,0.1);
    }

    .md-stats {
        display: flex;
        gap: 16px;
        padding: 8px 4px;
        font-size: 12px;
        color: var(--text-muted);
    }

    @media (max-width: 768px) {
        .md-editor-grid {
            grid-template-columns: 1fr;
            grid-template-rows: 1fr 1px 1fr;
        }
        .md-divider {
            height: 1px;
            width: 100%;
        }
    }
</style>
