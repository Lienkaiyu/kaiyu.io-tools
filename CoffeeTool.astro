<div class="tool-card" style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; min-height: 300px;">
    <div class="coffee-cup">
        <div class="steam">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div class="cup-body">
            <div class="cup-handle"></div>
        </div>
        <div class="saucer"></div>
    </div>
    
    <div class="controls" style="text-align: center;">
        <p id="status-text" class="tool-text" style="font-family: 'Courier New', Courier, monospace; margin-bottom: 15px; min-height: 1.2em;">Brewing your virtual coffee...</p>
        <button id="refill-btn" class="tool-btn tool-btn-primary" style="background-color: #795548; color: white; border-radius: 20px;">Refill Cup</button>
    </div>
</div>

<style>
    .coffee-cup {
        position: relative;
        margin-bottom: 30px;
    }

    .cup-body {
        width: 100px;
        height: 80px;
        background-color: #6f4e37; /* Coffee brown */
        border-radius: 0 0 50px 50px;
        position: relative;
        z-index: 2;
        background: linear-gradient(to right, #6f4e37, #5d4037);
    }

    .cup-body::before {
        content: '';
        position: absolute;
        top: -10px;
        left: 0;
        width: 100%;
        height: 20px;
        background-color: #795548;
        border-radius: 50%;
        z-index: 3;
    }

    .cup-body::after {
        content: '';
        position: absolute;
        top: -5px;
        left: 10px;
        width: 80px;
        height: 10px;
        background-color: #3e2723; /* Dark coffee liquid */
        border-radius: 50%;
        z-index: 4;
    }

    .cup-handle {
        position: absolute;
        top: 10px;
        right: -25px;
        width: 30px;
        height: 40px;
        border: 8px solid #5d4037;
        border-left: none;
        border-radius: 0 20px 20px 0;
        z-index: 1;
    }

    .saucer {
        position: absolute;
        bottom: -10px;
        left: -20px;
        width: 140px;
        height: 20px;
        background-color: #efebe9;
        border-radius: 50%;
        z-index: 1;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .steam {
        position: absolute;
        top: -40px;
        left: 20px;
        display: flex;
        gap: 10px;
        z-index: 0;
        opacity: 0;
        transition: opacity 0.5s;
    }

    .steam.active {
        opacity: 1;
    }

    .steam span {
        display: block;
        width: 8px;
        height: 30px;
        background-color: #ddd;
        border-radius: 50%;
        filter: blur(4px);
        animation: rise 2s infinite;
    }

    .steam span:nth-child(2) {
        animation-delay: 0.5s;
        height: 40px;
    }

    .steam span:nth-child(3) {
        animation-delay: 1s;
    }

    @keyframes rise {
        0% {
            transform: translateY(0) scaleX(1);
            opacity: 0;
        }
        50% {
            opacity: 0.8;
        }
        100% {
            transform: translateY(-40px) scaleX(1.5);
            opacity: 0;
        }
    }
</style>

<script>
    const btn = document.getElementById('refill-btn');
    const status = document.getElementById('status-text');
    const steam = document.querySelector('.steam');

    const messages = [
        "Brewing...",
        "Pouring...",
        "Adding love...",
        "Ready! ☕️"
    ];

    if (btn && status && steam) {
        btn.addEventListener('click', () => {
            btn.disabled = true;
            steam.classList.remove('active');
            
            let step = 0;
            status.textContent = messages[0];

            const interval = setInterval(() => {
                step++;
                if (step < messages.length) {
                    status.textContent = messages[step];
                } else {
                    clearInterval(interval);
                    steam.classList.add('active');
                    btn.disabled = false;
                    btn.textContent = "Drink & Refill";
                }
            }, 800);
        });

        // Initial brew
        setTimeout(() => btn.click(), 500);
    }
</script>
